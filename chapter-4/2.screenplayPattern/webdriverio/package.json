{
  "name": "webdriverio",
  "type": "module",
  "devDependencies": {
    "@serenity-js/assertions": "^3.41.2",
    "@serenity-js/console-reporter": "^3.41.2",
    "@serenity-js/core": "^3.41.2",
    "@serenity-js/mocha": "^3.41.2",
    "@serenity-js/rest": "^3.41.2",
    "@serenity-js/serenity-bdd": "^3.41.2",
    "@serenity-js/web": "^3.41.2",
    "@serenity-js/webdriverio": "^3.41.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@wdio/cli": "^9.25.0",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.25.0",
    "@wdio/spec-reporter": "^9.25.0",
    "cross-env": "^10.1.0",
    "expect-webdriverio": "^5.6.4",
    "mocha": "^11.7.5",
    "npm-failsafe": "^1.4.0",
    "open-cli": "^8.0.0",
    "rimraf": "^6.1.3"
  },
  "scripts": {
    "postinstall": "serenity-bdd update",
    "serenity": "failsafe serenity:clean wdio:chrome serenity:report",
    "serenity:clean": "rimraf target",
    "wdio:chrome": "wdio run ./config/chrome/chrome.conf.ts",
    "wdio:firefox": "wdio run ./config/firefox/firefox.conf.ts",
    "serenity:report": "serenity-bdd run",
    "serenity:open": "npm run serenity:report && npx open-cli ./target/site/serenity/index.html",
    "start": "mkdirp ./target/site/serenity && npx http-server -p 8080 ./target/site/serenity -s -o"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "dotenv": "^17.3.1"
  }
}